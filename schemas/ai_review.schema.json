{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/eraydin/semantic-pdf-diff/schemas/ai_review.schema.json",
  "title": "semantic-pdf-diff AI Review Report",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "source_schema_version",
    "old_fingerprint",
    "new_fingerprint",
    "summary",
    "question_hints",
    "review_items",
    "diagnostic_summary"
  ],
  "properties": {
    "schema_version": { "type": "string" },
    "source_schema_version": { "type": "string" },
    "old_fingerprint": { "type": "string" },
    "new_fingerprint": { "type": "string" },
    "summary": { "type": "object" },
    "question_hints": { "type": "array" },
    "review_items": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "tags": {
            "type": "array",
            "items": {
              "type": "string",
              "enum": [
                "TextChanged",
                "ContentInserted",
                "ContentDeleted",
                "ContentMoved",
                "LayoutOnly",
                "RepeatedPageRegion",
                "PaymentTermsCandidate",
                "DateOrDurationCandidate",
                "PartyNameCandidate",
                "NumericValueChanged",
                "AnnotationOrLinkChanged",
                "FormFieldChanged",
                "MetadataChanged",
                "VisualSurfaceChanged",
                "UnsupportedSurface",
                "LowConfidence"
              ]
            }
          },
          "evidence": {
            "type": "object",
            "properties": {
              "old_semantic_role": { "type": "string" },
              "new_semantic_role": { "type": "string" }
            }
          }
        }
      }
    },
    "diagnostic_summary": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["code", "count"],
        "properties": {
          "code": { "type": "string" },
          "count": { "type": "integer", "minimum": 0 }
        }
      }
    }
  }
}
