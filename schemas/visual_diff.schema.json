{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/eraydin/semantic-pdf-diff/schemas/visual_diff.schema.json",
  "title": "semantic-pdf-diff Visual Diff Report",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "old_file",
    "new_file",
    "renderer",
    "pixel_threshold",
    "summary",
    "pages",
    "diagnostics"
  ],
  "properties": {
    "schema_version": { "type": "string" },
    "old_file": { "type": "string" },
    "new_file": { "type": "string" },
    "renderer": {
      "type": "object",
      "additionalProperties": false,
      "required": ["command_configured", "output_format", "page_file_pattern"],
      "properties": {
        "command_configured": { "type": "boolean" },
        "output_format": { "type": "string" },
        "page_file_pattern": { "type": "string" }
      }
    },
    "pixel_threshold": { "type": "integer", "minimum": 0, "maximum": 255 },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "compared_pages",
        "equal_pages",
        "changed_pages",
        "missing_old_pages",
        "missing_new_pages",
        "dimension_mismatch_pages",
        "total_pixels",
        "changed_pixels",
        "max_channel_delta"
      ],
      "properties": {
        "compared_pages": { "type": "integer", "minimum": 0 },
        "equal_pages": { "type": "integer", "minimum": 0 },
        "changed_pages": { "type": "integer", "minimum": 0 },
        "missing_old_pages": { "type": "integer", "minimum": 0 },
        "missing_new_pages": { "type": "integer", "minimum": 0 },
        "dimension_mismatch_pages": { "type": "integer", "minimum": 0 },
        "total_pixels": { "type": "integer", "minimum": 0 },
        "changed_pixels": { "type": "integer", "minimum": 0 },
        "max_channel_delta": { "type": "integer", "minimum": 0, "maximum": 255 }
      }
    },
    "pages": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "page_index",
          "status",
          "old_image",
          "new_image",
          "total_pixels",
          "changed_pixels",
          "changed_pixel_ratio",
          "max_channel_delta",
          "heatmap"
        ],
        "properties": {
          "page_index": { "type": "integer", "minimum": 0 },
          "status": {
            "type": "string",
            "enum": [
              "equal",
              "changed",
              "missing_old",
              "missing_new",
              "dimension_mismatch"
            ]
          },
          "old_image": { "$ref": "#/$defs/image_info" },
          "new_image": { "$ref": "#/$defs/image_info" },
          "total_pixels": { "type": "integer", "minimum": 0 },
          "changed_pixels": { "type": "integer", "minimum": 0 },
          "changed_pixel_ratio": { "type": "number", "minimum": 0 },
          "max_channel_delta": { "type": "integer", "minimum": 0, "maximum": 255 },
          "heatmap": { "type": ["string", "null"] }
        }
      }
    },
    "diagnostics": {
      "type": "array",
      "items": { "$ref": "#/$defs/diagnostic" }
    }
  },
  "$defs": {
    "image_info": {
      "type": ["object", "null"],
      "additionalProperties": false,
      "required": ["width", "height", "hash"],
      "properties": {
        "width": { "type": "integer", "minimum": 0 },
        "height": { "type": "integer", "minimum": 0 },
        "hash": { "type": "string" }
      }
    },
    "diagnostic": {
      "type": "object",
      "required": ["severity", "code", "message"],
      "properties": {
        "severity": { "type": "string" },
        "code": { "type": "string" },
        "message": { "type": "string" },
        "provenance": {}
      }
    }
  }
}
